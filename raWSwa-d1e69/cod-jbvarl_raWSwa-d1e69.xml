      <div xml:id="raWSwa-d1e69"><!-- raWSwa-c1 -->
        <head xml:id="raWSwa-d1e69-Hd1e101">Caput 1</head>
        <head xml:id="raWSwa-d1e69-Hd1e103" type="question-title">De rebus specialiter Deo consecratis</head>
        <p xml:id="raWSwa-d1e69-d1e106">
          <!-- omitted -->
        </p>
        <p xml:id="raWSwa-d1e69-d1e113">
          Auctor uniuersitatis re<lb ed="#R" n="17" break="no"/>rum 
          altissimus et creator <pc type="punctus"/> unde et merito omnium est dominus de quo in psalmo
          <lb ed="#R" n="18"/><quote xml:id="raWSwa-d1e69-Qd1e131" source="http://scta.info/resource/ps23_1@5-10">dominum est terra et plenitudo eius</quote> de illa uniuersitate quaedam specialia et 
          <lb ed="#R" n="19"/>specialiter sibi retinuit <pc type="punctus"/> <unclear>iudelis</unclear> de locis loca ueneranda <pc type="punctus"/> et de temporibus 
          <lb ed="#R" n="20"/>sollempnes ferias <pc type="punctus"/> et de rebus decimas et primitias et oblationes et cetera 
          <lb ed="#R" n="21"/>donaria de personis quasdam sibi dicatas <pc type="punctus"/> ministors scilicet altaris monachos 
          <lb ed="#R" n="22"/>moniales <pc type="punctus"/> De his ergo quatuor <pc type="punctus"/> scilicet locis <pc type="punctus"/> temporibus <pc type="punctus"/> rebus <pc type="punctus"/> et personis <pc type="punctus"/> et earum 
          <lb ed="#R" n="23"/>personarum multiplicibus officiis <pc type="punctus"/> dicendum est <pc type="punctus"/> et primo de locis <pc type="punctus"/> 
        </p>
      </div>
